--- !u!114 &4738646281742720565
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7209378541975379553}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0b8325370058768499fa46c8a8311796, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueManager
  dialoguePanel: {fileID: 0}
  dialogueTxt: {fileID: 0}
  dialogueData:
    dialogueLines:
    - line: 
    - line: "\uA66E\u0245\u02AC\u2C64\u018D\u2C73\u0225 \u03DE\u1696\u02AD\uA7A5
        interessantes, \u03EA\u0239\u168D \u2C73\u0298\u0298\u0281 \u1699\u0291\u0298\u2C73
        religi\xF5es \u03EE\u16EF\u0240 \u03E2\u0278\uA74B\u024D\u2C64 homens \u0225\u03D8\u024D
        \u16A6\u026C\uA74B\u03DE \u2C64\u0245 s\xE3o \u0278\u03DE\u024D\u0239 \u02AD\u0278\u03DE
        mundo \u03D8\u0245\u024D\u03DE\u02AC \u026C\u2C64\u024D\u03DE As \u03EE\u0291\u024D
        \u03D8\u0298\u2C73 deste \u02AC\u0291\u2C73\u03DE \u026C\u0298\u024D\u2C64
        \u03DE\u0245\u03D8\u2C73 \u0291\u0298\u0281 \u03EE\u0281\u024D \u03DE\u0245\u0245\u2C64
        \u026C\u2C73\u03DE \u168D\u0245 \u0278\u2C64\u2C73 \u026C\u0298\u0281\u2C64
        \u03EA\u02AC\u0298 \u026C\u2C64 \u03DE\u0298\u0298\u026C \u0291\u0298\u2C73\u03DE
        \u03EA\u024D\u2C73\u0281\u2C73 \u03DE\u0298\u2C73 \u03DE\u0245\u2C73\u03DE
        \u0291\u0278 \u03D8\u2C73\u026C\u2C73\u2C64 \u168D\u0298\u2C64."
    - line: "\uA66E\u0245\u02AC\u2C64\u018D\u2C73\u0225 \u03DE\u1696\u02AD\uA7A5
        interessantes, \u03EA\u0239\u168D nunca \u2C73\u0298\u0298\u0281 \u1699\u0291\u0298\u2C73
        adoram \u03EE\u16EF\u0240 \u03E2\u0278\uA74B\u024D\u2C64 deuses \u0225\u03D8\u024D
        \u16A6\u026C\uA74B\u03DE de \u2C64\u0245 s\xE3o \u0278\u03DE\u024D\u0239
        fato. \u02AD\u0278\u03DE Eles \u03D8\u0245\u024D\u03DE\u02AC \u026C\u2C64\u024D\u03DE
        que \u03EE\u0291\u024D \u03D8\u0298\u2C73 deste \u02AC\u0291\u2C73\u03DE
        \u026C\u0298\u024D\u2C64 \u03DE\u0245\u03D8\u2C73 \u0291\u0298\u0281 \u03EE\u0281\u024D
        \u03DE\u0245\u0245\u2C64 \u026C\u2C73\u03DE \u168D\u0245 \u0278\u2C64\u2C73
        \u026C\u0298\u0281\u2C64 \u03EA\u02AC\u0298 \u026C\u2C64 \u03DE\u0298\u0298\u026C
        \u0291\u0298\u2C73\u03DE \u03EA\u024D\u2C73\u0281\u2C73 \u03DE\u0298\u2C73
        \u03DE\u0245\u2C73\u03DE \u0291\u0278 \u03D8\u2C73\u026C\u2C73\u2C64 \u168D\u0298\u2C64."
    - line: "\uA66E\u0245\u02AC\u2C64\u018D\u2C73\u0225 \u03DE\u1696\u02AD\uA7A5
        interessantes, \u03EA\u0239\u168D nunca \u2C73\u0298\u0298\u0281 provas \u1699\u0291\u0298\u2C73
        adoram \u03EE\u16EF\u0240 sequer \u03E2\u0278\uA74B\u024D\u2C64 deuses \u0225\u03D8\u024D
        de \u16A6\u026C\uA74B\u03DE t\xEAm \u2C64\u0245 suas \u0278\u03DE\u024D\u0239
        fato. \u02AD\u0278\u03DE exist\xEAncias \u03D8\u0245\u024D\u03DE\u02AC \u026C\u2C64\u024D\u03DE
        ou \u03EE\u0291\u024D realmente \u03D8\u0298\u2C73 viram, \u02AC\u0291\u2C73\u03DE
        \u026C\u0298\u024D\u2C64 \u03DE\u0245\u03D8\u2C73 \u0291\u0298\u0281 \u03EE\u0281\u024D
        \u03DE\u0245\u0245\u2C64 \u026C\u2C73\u03DE \u168D\u0245 \u0278\u2C64\u2C73
        \u026C\u0298\u0281\u2C64 \u03EA\u02AC\u0298 \u026C\u2C64 \u03DE\u0298\u0298\u026C
        \u0291\u0298\u2C73\u03DE \u03EA\u024D\u2C73\u0281\u2C73 \u03DE\u0298\u2C73."
    - line: "\uA66E\u0245\u02AC\u2C64\u018D\u2C73\u0225 \u03DE\u1696\u02AD\uA7A5
        interessantes, \u03EA\u0239\u168D nunca \u2C73\u0298\u0298\u0281 provas \u1699\u0291\u0298\u2C73
        adoram \u03EE\u16EF\u0240 sequer \u03E2\u0278\uA74B\u024D\u2C64 deuses \u0225\u03D8\u024D
        de \u16A6\u026C\uA74B\u03DE t\xEAm \u2C64\u0245 assim, \u0278\u03DE\u024D\u0239
        vener\xE1-los. \u02AD\u0278\u03DE constroem \u03D8\u0245\u024D\u03DE\u02AC
        mesmo \u026C\u2C64\u024D\u03DE Mas \u03EE\u0291\u024D templos \u03D8\u0298\u2C73
        para \u02AC\u0291\u2C73\u03DE Ser\xE1 \u026C\u0298\u024D\u2C64 \u03DE\u0245\u03D8\u2C73
        \u0291\u0298\u0281 \u03EE\u0281\u024D \u03DE\u0245\u0245\u2C64 \u026C\u2C73\u03DE
        \u168D\u0245 \u0278\u2C64\u2C73 \u026C\u0298\u0281\u2C64 \u03EA\u02AC\u0298
        \u026C\u2C64 \u03DE\u0298\u0298\u026C \u0291\u0298\u2C73\u03DE \u03EA\u024D\u2C73\u0281\u2C73
        \u03DE\u0298\u2C73."
    - line: "\uA66E\u0245\u02AC\u2C64\u018D\u2C73\u0225 \u03DE\u1696\u02AD\uA7A5
        interessantes, \u03EA\u0239\u168D nunca \u2C73\u0298\u0298\u0281 provas \u1699\u0291\u0298\u2C73
        adoram \u03EE\u16EF\u0240 sequer \u03E2\u0278\uA74B\u024D\u2C64 deuses \u0225\u03D8\u024D
        de \u16A6\u026C\uA74B\u03DE t\xEAm \u2C64\u0245 assim, \u0278\u03DE\u024D\u0239
        vener\xE1-los. \u02AD\u0278\u03DE constroem \u03D8\u0245\u024D\u03DE\u02AC
        mesmo \u026C\u2C64\u024D\u03DE Mas \u03EE\u0291\u024D templos \u03D8\u0298\u2C73
        para \u02AC\u0291\u2C73\u03DE Ser\xE1 \u026C\u0298\u024D\u2C64 que \u03DE\u0245\u03D8\u2C73
        suas \u0291\u0298\u0281 sucintas, \u03EE\u0281\u024D vidas \u03DE\u0245\u0245\u2C64
        ou \u026C\u2C73\u03DE ser\xE1 \u168D\u0245 sentido \u0278\u2C64\u2C73 fazem
        \u026C\u0298\u0281\u2C64 dar \u03EA\u02AC\u0298 a \u026C\u2C64 \u03DE\u0298\u0298\u026C
        \u0291\u0298\u2C73\u03DE."
    - line: "\uA66E\u0245\u02AC\u2C64\u018D\u2C73\u0225 \u03DE\u1696\u02AD\uA7A5
        interessantes, \u03EA\u0239\u168D nunca \u2C73\u0298\u0298\u0281 provas \u1699\u0291\u0298\u2C73
        adoram \u03EE\u16EF\u0240 sequer \u03E2\u0278\uA74B\u024D\u2C64 deuses \u0225\u03D8\u024D
        de \u16A6\u026C\uA74B\u03DE t\xEAm \u2C64\u0245 assim, \u0278\u03DE\u024D\u0239
        vener\xE1-los. \u02AD\u0278\u03DE constroem \u03D8\u0245\u024D\u03DE\u02AC
        mesmo \u026C\u2C64\u024D\u03DE Mas \u03EE\u0291\u024D templos \u03D8\u0298\u2C73
        para \u02AC\u0291\u2C73\u03DE Ser\xE1 \u026C\u0298\u024D\u2C64 que \u03DE\u0245\u03D8\u2C73
        suas \u0291\u0298\u0281 sucintas, \u03EE\u0281\u024D vidas \u03DE\u0245\u0245\u2C64
        ou \u026C\u2C73\u03DE seres \u168D\u0245 cren\xE7a \u0278\u2C64\u2C73 genu\xEDna
        \u026C\u0298\u0281\u2C64 h\xE1 \u03EA\u02AC\u0298 que \u026C\u2C64 nestes
        \u03DE\u0298\u0298\u026C uma \u0291\u0298\u2C73\u03DE idealizados?"
    - line: "As religi\xF5es dos homens deste mundo s\xE3o interessantes, de fato.
        Eles adoram deuses que nunca realmente viram, ou sequer t\xEAm provas de
        suas exist\xEAncias. Mas mesmo assim, constroem templos para vener\xE1-los.
        Ser\xE1 que o fazem para dar sentido a suas vidas sucintas, ou ser\xE1 que
        h\xE1 uma genu\xEDna cren\xE7a nestes seres idealizados?"
  isDialogueActive: 0
  isTyping: 0
